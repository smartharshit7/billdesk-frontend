# ─────────────────────────────────────────────────────────────
# BillDesk v2 — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# MongoDB
# Local:  mongodb://localhost:27017/billdesk
# Atlas:  mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/billdesk
MONGO_URI=mongodb://localhost:27017/billdesk

# JWT — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# Server port
PORT=4000

# ── Email (for Forgot Password reset emails) ──────────────────
# Use your Gmail address + a Gmail App Password
# Get App Password: https://myaccount.google.com/apppasswords
# (Enable 2-Step Verification first, then create App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourname@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# ── Google OAuth (for Sign in with Google) ─────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID → Web Application
# 4. Add Authorised JavaScript origins: http://localhost:3000
# 5. Copy the Client ID here
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Frontend URL (used in password reset emails) ──────────────
# Where your React app is hosted (reset link will point here)
FRONTEND_URL=http://localhost:3000
